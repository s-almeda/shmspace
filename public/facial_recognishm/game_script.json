    "id": 12,
    "toggles": { "bbox": true, "facemesh": true, "race": true, "age": true, "gender": true, "emotion": true, "hands": false },
    "dialogue": { "show": true, "characterName": "shm", "text": "maybe they have a better model loaded in?" },
    "actionRequired": null
  },
  {
    "id": 13,
    "toggles": {},
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "....and maybe i have some sh*tty one that was only trained for like 5 epochs but then the gpu fan started making weird noises so they stopped trying" },

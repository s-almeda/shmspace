[
  {
    "id": 1,
    "toggles": { "bbox": false, "facemesh": false, "race": false, "age": false, "gender": false, "emotion": false, "hands": false },
    "dialogue": { "show": true, "characterName": "shm", "text": "..." },
    "actionRequired": null
  },
  {
    "id": 2,
    "toggles": {"credits": false},
    "dialogue": { "show": true, "characterName": "shm", "text": "what's up chat" },
    "actionRequired": null
  },
  {
    "id": 3,
    "toggles": { "bbox": true },
    "dialogue": { "show": true, "characterName": "shm", "text": "i don't really know what my face looks like. and I've been trying to figure this out for a very long time." },
    "actionRequired": null
  },
  {
    "id": 4,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "and. i think this has had weird effects on my development. like. i used to spend a loooot of time staring at mirrors as a kid" },
    "actionRequired": null
  },
  {
    "id": 5,
    "toggles": { "hands": true, "puppetNum": 1 },
    "dialogue": { "show": true, "characterName": "shm", "text": "and over the years i've made a lot of self portraits." },
    "actionRequired": null
  },
  {
    "id": 6,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "...like, a lot..... this isn't even half of them... i like this one...." },
    "actionRequired": null
  },
  {
    "id": 7,
    "toggles": { },
    "dialogue": { "show": true, "characterName": "shm", "text": "maybe i'm just like, obsessed with myself and my appearance." },
    "actionRequired": null
  },
  {
    "id": 8,
    "toggles": {"hands": false, "facemesh": false},
    "dialogue": { "show": true, "characterName": "shm", "text": "and this is a reasonable assumption. like. who wouldn't be obsessed with me. after all, I'm..." },
    "actionRequired": null
  },
  {
    "id": 9,
    "toggles": { "detectPrettyCute": true },
    "dialogue": null,
    "actionRequired": "prettyCute"
  },
  {
    "id": 10,
    "toggles": { "detectPrettyCute": false, "facemesh": false },
    "dialogue": { "speed": "medium", "show": true, "characterName": "shm", "text": "it's just that, like, the task of processing faces..... especially my own, has always felt....weirdly unintuitive." },
    "actionRequired": null
  },
  {
    "id": 11,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "i often get the sense that other people can just like. do facial recognition a lot better than me." },
    "actionRequired": null
  },
  {
    "id": 12,
    "toggles": { "bbox": true, "facemesh": true, "race": true, "age": true, "gender": true, "emotion": true, "hands": false },
    "dialogue": { "show": true, "characterName": "shm", "text": "like, maybe they have a better model loaded in?" },
    "actionRequired": null
  },
  {
    "id": 13,
    "toggles": {},
    "dialogue": { "speed": "medium", "show": true, "characterName": "shm", "text": "....and maybe i have a sh*tty one that was only trained for like 5 epochs. and then the gpu fan started making weird noises" },
    "actionRequired": null
  },
  {
    "id": 14,
    "toggles": { "hands": true, "puppetNum": 13 },
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "...and maybe my initial dataset was mostly tumblr and deviantart... so now my vision system is like ...overfit to anime faces..." },
    "actionRequired": null
  },
  {
    "id": 15,
    "toggles": { "hands": true, "puppetNum": 16 },
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "and hedgehogs" },
    "actionRequired": null
  },
  {
    "id": 16,
    "toggles": { "bbox": true, "facemesh": false, "race": false, "age": false, "gender": false, "emotion": false, "hands": true, "puppetNum": 4 },
    "dialogue": { "show": true, "characterName": "shm", "text": "i think this is what drew me to become so obsessive about portraiture, what led me to dedicate myself to learning how to depict likeness in my art" },
    "actionRequired": null
  },
  {
    "id": 17,
    "toggles": { "facemesh": true },
    "dialogue": { "show": true, "characterName": "shm", "text": "i thought that if i could accurately perceive and record every salient feature of a face i could manually force myself to understand what maybe everyone else is seeing when they..." },
    "actionRequired": null
  },
  {
    "id": 17,
    "toggles": {"puppetNum": 5},
    "dialogue": { "show": true, "characterName": "shm", "text": "look at each other" },
    "actionRequired": null
  },
  {
    "id": 18,
    "toggles": {"facemesh":false},
    "dialogue": { "show": true, "characterName": "shm", "text": "when they look at me" },
    "actionRequired": null
  },
  {
    "id": 19,
    "toggles": {"hands":false},
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "and maybe if i understood how i was being perceived, i could control that." },
    "actionRequired": null
  },
  {
    "id": 20,
    "toggles": {},
    "dialogue": { "speed": "medium", "show": true, "characterName": "shm", "text": "or i could at least... try to... explain." },
    "actionRequired": null
  },
  {
    "id": 22,
    "toggles": { "race": true, "gender": true, "age": true },
    "dialogue": { "show": true, "characterName": "shm", "text": "years before i had the words to articulate why, it bothered me. that when people looked at me, they were clearly perceiving things that i didn't realize were... there... and had no control over." },
    "actionRequired": null
  },
  {
    "id": 23,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "i grew up in a very white community. and i loved that community and i still do." },
    "actionRequired": null
  },
  {
    "id": 24,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "and to be clear i am something like a...." },
    "actionRequired": null
  },
  {
    "id": 25,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "like, i'm speaking from a place of immense privilege here." },
    "actionRequired": null
  },
  {
    "id": 26,
    "toggles": {"bbox": false, "facemesh": false},
    "dialogue": { "show": true, "characterName": "shm", "text": "most people i grew up with were always trying to be nice and relate to me. we were all just. sometimes kinda ...awkward about it." },
    "actionRequired": null
  },

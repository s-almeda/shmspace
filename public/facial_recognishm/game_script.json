    "actionRequired": "prettyCute"
  },
  {
    "id": 10,
    "toggles": { "detectPrettyCute": false, "facemesh": false },
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "it's just that, like, the task of processing faces..... especially my own, has always felt....weirdly unintuitive." },
    "actionRequired": null
  },
  {
    "id": 11,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "i often get the sense that other people can just like. do facial recognition better than me." },
    "actionRequired": null
  },

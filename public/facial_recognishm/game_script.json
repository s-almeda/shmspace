    "id": 15,
    "toggles": { "hands": true, "puppetNum": 14 },
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "and hedgehogs" },
    "actionRequired": null
  },
  {
    "id": 16,
    "toggles": { "bbox": true, "facemesh": false, "race": false, "age": false, "gender": false, "emotion": false, "hands": false },
    "dialogue": { "show": true, "characterName": "shm", "text": "i think this is what drew me to become so obsessive about portraiture, and learning to depict likeness in my art" },
    "actionRequired": null
  },
  {
    "id": 17,
    "toggles": { "facemesh": true },
    "dialogue": { "show": true, "characterName": "shm", "text": "i thought that if i could accurately perceive and record every salient feature of a face i could manually force myself to understand what maybe everyone else is seeing when they..." },
    "actionRequired": null
  },
  {
    "id": 17,
    "toggles": {},
    "dialogue": { "show": true, "characterName": "shm", "text": "look at each other" },

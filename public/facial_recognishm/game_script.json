  {
    "id": 14,
    "toggles": { "hands": true, "puppetNum": 13 },
    "dialogue": { "speed": "slow", "show": true, "characterName": "shm", "text": "...and maybe my initial dataset was mostly tumblr and deviantart... and now im like ...overfit to anime faces..." },
    "actionRequired": null
  },
